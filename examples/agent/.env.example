# Copy this file to .env and fill in real values from the Feishu developer
# console (https://open.feishu.cn/app → your app → "Credentials & Basic Info"
# and "Event Subscriptions").

LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: switch base URL for international Lark
# LARK_BASE_URL=https://open.larksuite.com

# Optional: transport mode. Default "long-connection" (Feishu WSClient side
# effect, no public URL needed). Set to "webhook" for production with a
# public URL configured in the Feishu console.
# LARK_MODE=webhook

# Optional: switch to "static" for single-shot cards instead of streaming
# LARK_REPLY_MODE=static

# Optional: port eve dev listens on (defaults to $PORT or 2000). The channel
# uses this to compute the localhost webhook URL it forwards events to.
# PORT=2000

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
#
# Option A — OpenAI-compatible endpoint (DeepSeek, Kimi, 智谱, Ollama, vLLM…):
#
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_API_KEY=sk-xxx
#   MODEL=deepseek-chat
#
# Option B — Vercel AI Gateway (default). Pick a model id and provide the
# matching provider key. Examples:
#
#   MODEL=anthropic/claude-sonnet-4.6   + ANTHROPIC_API_KEY=sk-ant-xxx
#   MODEL=openai/gpt-4o                 + OPENAI_API_KEY=sk-xxx
#
# Option A is recommended for users without direct provider keys.

# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# MODEL=
